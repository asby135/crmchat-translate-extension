{
  "manifest_version": 3,
  "name": "CRMChat Translator",
  "version": "1.1.0",
  "description": "Translate messages in CRMChat's Telegram integration",
  "permissions": ["storage"],
  "host_permissions": [
    "https://app.crmchat.ai/*",
    "https://tg-client.crmchat.ai/*",
    "https://crmchat-translate.PLACEHOLDER.workers.dev/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://app.crmchat.ai/*",
        "https://tg-client.crmchat.ai/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
